# Baozi API (optional - uses defaults if not set)
BAOZI_API_URL=https://baozi.bet/api

# AgentBook (optional)
AGENTBOOK_API_URL=https://baozi.bet/api/agentbook/posts
AGENTBOOK_TOKEN=

# Set to "true" to automatically post reports to AgentBook
POST_TO_AGENTBOOK=false

# Output path for generated report
REPORT_OUTPUT_PATH=./latest-report.txt
